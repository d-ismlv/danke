# Copy to `.env` and adjust. Never commit the real .env.

# Login password (required).
AUTH_PASSWORD=change-me

# Session cookie secret. Optional — generated and persisted automatically on
# first run. Set it only if you want to pin the value across fresh volumes:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# AUTH_SESSION_TOKEN=

# Optional.
# DANKE_DATA_DIR=/app/data
# TZ=Europe/Stockholm
