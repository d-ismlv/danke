# Copy to `.env` next to docker-compose.yml on the server (Komodo can also
# inject these as stack environment / secrets). Never commit the real .env.

# The password you type on the login page.
DANKE_AUTH_PASSWORD=change-me-16-chars

# Opaque random value stored in the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
DANKE_AUTH_SESSION_TOKEN=change-me-random-hex

# Optional, used for timestamps/logging.
TZ=Europe/Stockholm
